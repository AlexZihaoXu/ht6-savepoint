# Copy to `.env` and fill in. All vars use the SAVEPOINT_ prefix.
# Secrets stay in .env (gitignored) — never commit real keys.

SAVEPOINT_APP_NAME="SavePoint Server"
SAVEPOINT_HOST=0.0.0.0
SAVEPOINT_PORT=8000
# JSON list of allowed CORS origins
SAVEPOINT_CORS_ORIGINS=["*"]

# MongoDB (local default; use an Atlas SRV URI in prod)
SAVEPOINT_MONGO_URI=mongodb://127.0.0.1:27017
SAVEPOINT_MONGO_DB=savepoint

# LLM backends for recaps/bios
SAVEPOINT_GEMMA_BASE_URL=http://127.0.0.1:8000/v1
# SAVEPOINT_GEMINI_API_KEY=
# SAVEPOINT_BACKBOARD_API_KEY=

# Speech pipeline (SAV-32). "stub" (default) is CI-safe / no torch; "real" shells
# out to jiucheng's vendored pipeline in its own venvs (outside the repo).
SAVEPOINT_TRANSCRIBER=stub
# RealTranscriber only — pipeline dir + per-stage interpreters + HF token.
# SAVEPOINT_SPEECH_PIPELINE_DIR=/home/agent/two-speaker-demo
# SAVEPOINT_SPEECH_DIARIZE_PYTHON=/home/agent/two-speaker-demo/.venv/bin/python
# SAVEPOINT_SPEECH_ALIGN_PYTHON=/home/agent/two-speaker-demo/.venv-stream/bin/python
# SAVEPOINT_SPEECH_WHISPER_MODEL=small.en
# SAVEPOINT_HF_TOKEN=
