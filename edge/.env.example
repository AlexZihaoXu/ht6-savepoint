# SavePoint edge (Pi 5) — example environment. Copy to `.env` and edit.
# `.env` is gitignored; this `.env.example` is tracked as the reference.

# ── Backend: where capture comes from ───────────────────────────────
# "sim" (default) = synthetic camera/mute/detector, no hardware.
# "linux"         = real Pi 5 (picamera2 + gpiozero + onnxruntime).
SAVEPOINT_EDGE_BACKEND=linux

# ── Sink: where derived events go ───────────────────────────────────
# The server accepts a JSON array of EdgeEvents at POST /ingest/video
# (list[EdgeEvent]) — HttpSink posts each event as a one-element array.
# Use an IP literal (tailnet IP or the cloudflared origin) so the sink's
# timeout stays meaningful; point it at the /ingest/video path exactly.
#   stdout            -> one JSON line per event (default)
#   file:<path>       -> newline-delimited JSON file
#   http://.../ingest/video -> POST to the server
SAVEPOINT_EDGE_SINK=http://100.64.151.86:8000/ingest/video

# ── Face models (linux backend only) ────────────────────────────────
# ONNX model paths for detection + embedding. Not committed to the repo;
# provide them on the Pi. Leave blank on the sim backend.
SAVEPOINT_EDGE_FACE_MODEL=/home/pi/models/scrfd.onnx
SAVEPOINT_EDGE_FACE_EMBED_MODEL=/home/pi/models/arcface.onnx

# ── Identity matching (optional tuning) ─────────────────────────────
# Defaults (0.30 / 0.15) already favor NOT fragmenting one person into
# several ids on a head turn, at some risk of merging two people who
# happen to overlap — see identity_gallery.py's docstring for the
# trade-off. Loosen further (lower) if the same person still splits into
# multiple ids; tighten (raise) if two different people are merging into
# one. Tune against real footage, then edit here and restart — no
# redeploy needed.
# SAVEPOINT_EDGE_SIMILARITY_THRESHOLD=0.30
# SAVEPOINT_EDGE_IOU_THRESHOLD=0.15
# SAVEPOINT_EDGE_CENTER_DISTANCE_THRESHOLD=0.5
#
# How long someone must be continuously present before a "seen" event
# fires at all (default 3000ms) — raise if brief walk-throughs are still
# getting recorded, lower if genuine stays are getting missed.
# SAVEPOINT_EDGE_MIN_PRESENCE_MS=3000

# ── Debug view (optional) ───────────────────────────────────────────
# Unset by default. Set to a port (e.g. 8090) to serve a live MJPEG view
# (camera + SCRFD boxes) at http://<pi>:<port>/ from THIS SAME process —
# no need to stop the service to see it. Leave commented out normally.
# SAVEPOINT_EDGE_DEBUG_PORT=8090
